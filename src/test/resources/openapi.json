{
  "openapi": "3.1.0",
  "info": {
    "title": "API Title",
    "version": "0.0.1-local"
  },
  "servers": [
    {
      "url": "http://localhost:8080/api/v1"
    }
  ],
  "paths": {
    "/data": {
      "get": {
        "operationId": "get-data",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "description": "Response body",
                "schema": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "integer"
                    }
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "post-data",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "id": {
                    "type": "string",
                    "pattern": "^s.+d$"
                  },
                  "age": {
                    "type": "integer"
                  },
                  "score": {
                    "type": "number"
                  },
                  "random": {
                    "type": "string",
                    "format": "uuid"
                  },
                  "status": {
                    "type": "string",
                    "enum": [ "COMPLETED", "ERROR" ]
                  },
                  "feelingGood": {
                    "type": "boolean"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "description": "Response body",
                "schema": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
